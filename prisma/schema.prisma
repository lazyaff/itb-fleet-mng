// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                          String            @id @default(uuid())
  role_id                     String
  admin_id                    String?
  email                       String            @unique
  password                    String?
  name                        String
  active                      Boolean           @default(true)
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  deleted_at                  DateTime?

  role                        role              @relation(fields: [role_id], references: [id])
  admin                       user?             @relation("UserToAdmin", fields: [admin_id], references: [id])
  inspectors                  user[]            @relation("UserToAdmin")
  general_vehicle_part        general_vehicle_part[]
  vehicles                    vehicle[]
  service_histories           service_history[]
  inspection_reports          inspection_report[]
}

model role {
  id                          String            @id
  name                        String   
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  deleted_at                  DateTime?

  users                       user[]
}

model gps_tracker {
  id                          String            @id @default(uuid())
  imei                        String   
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  deleted_at                  DateTime?

  vehicle                     vehicle?
  live_tracks                 live_track_history[]
}

model vehicle_type {
  id                          String            @id @default(uuid())
  name                        String   
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  deleted_at                  DateTime?

  vehicles                    vehicle[]
}

model vehicle {
  id                          String            @id @default(uuid())
  user_id                     String?
  type_id                     String
  gps_tracker_id              String?           @unique
  plate_number                String
  name                        String
  image                       String
  internal_code               String?
  status                      String
  notes                       String?
  current_mileage             Int
  engine_hours                Int
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  user                        user?              @relation(fields: [user_id], references: [id])
  vehicle_type                vehicle_type       @relation(fields: [type_id], references: [id])
  gps_tracker                 gps_tracker?       @relation(fields: [gps_tracker_id], references: [id])
  live_tracks                 live_track_history[]
  vehicle_parts               vehicle_part[]
  service_histories           service_history[]
  inspection_reports          inspection_report[]
}

model live_track_history {
  id                          String             @id @default(uuid())
  vehicle_id                  String?
  gps_tracker_id              String
  speed                       Int
  battery_voltage             Int
  lat                         Float
  long                        Float
  angle                       Int
  ignition                    Boolean
  movement                    Boolean
  gsm_signal_strength         Int
  total_mileage               Int
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  vehicle                     vehicle?           @relation(fields: [vehicle_id], references: [id])
  gps_tracker                 gps_tracker        @relation(fields: [gps_tracker_id], references: [id])
}

model general_vehicle_part {
  id                          String             @id @default(uuid())
  user_id                     String?
  name                        String
  distance_limit              Int
  time_limit                  Int
  active                      Boolean
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  user                        user?              @relation(fields: [user_id], references: [id])
  vehicle_parts               vehicle_part[]
}

model vehicle_part {
  id                          String             @id @default(uuid())
  vehicle_id                  String
  general_vehicle_part_id     String?
  name                        String
  last_service                DateTime
  current_distance            Int
  distance_limit              Int
  time_limit                  Int
  notes                       String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  vehicle                     vehicle                          @relation(fields: [vehicle_id], references: [id])
  general_vehicle_part        general_vehicle_part?            @relation(fields: [general_vehicle_part_id], references: [id])
  service_histories           vehicle_part_service_history[]
}

model service_history {
  id                          String             @id @default(uuid())
  vehicle_id                  String
  user_id                     String
  image                       String
  current_mileage             Int
  date                        DateTime
  type                        String
  cost                        Int
  notes                       String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  vehicle                     vehicle            @relation(fields: [vehicle_id], references: [id])
  user                        user               @relation(fields: [user_id], references: [id])
}

model vehicle_part_service_history {
  id                          String             @id @default(uuid())
  vehicle_part_id             String
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  vehicle_part                vehicle_part       @relation(fields: [vehicle_part_id], references: [id])
}

model inspection_section {
  id                          String             @id @default(uuid())
  title                       String  
  order                       Int
  icon                        String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  questions inspection_question[]
}

model inspection_question {
  id                          String             @id @default(uuid())
  section_id                  String
  title                       String   
  order                       Int
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  section                     inspection_section               @relation(fields: [section_id], references: [id])
  options                     inspection_option[]
  answers                     inspection_answer[]
}

model inspection_option {
  id                          String             @id @default(uuid())
  question_id                 String
  label                       String   
  description                 String   
  value                       Int     
  order                       Int
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  question                    inspection_question              @relation(fields: [question_id], references: [id])
  answers                     inspection_answer[]
}

model inspection_report {
  id                          String             @id @default(uuid())
  user_id                     String
  vehicle_id                  String
  date                        DateTime
  conclusion                  String?  
  notes                       String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  user                        user               @relation(fields: [user_id], references: [id])
  vehicle                     vehicle            @relation(fields: [vehicle_id], references: [id])
  answers                     inspection_answer[]
}

model inspection_answer {
  id                          String             @id @default(uuid())
  report_id                   String
  question_id                 String
  option_id                   String
  section_title               String
  section_order               Int
  section_icon                String
  question_title              String
  question_order              Int
  option_label                String
  option_desc                 String
  option_value                Int
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  deleted_at                  DateTime?

  report                      inspection_report              @relation(fields: [report_id], references: [id])
  question                    inspection_question            @relation(fields: [question_id], references: [id])
  option                      inspection_option              @relation(fields: [option_id], references: [id])
}
